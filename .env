# ========================
# Registry
# ========================
REGISTRY_URL=docker.io/rabotyaga00
TAG=latest

# ========================
# Environment
# ========================
NODE_ENV=production

# ========================
# Product Service DB
# ========================
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=password
PRODUCT_DB_NAME=product_db

# ========================
# Order Service DB
# ========================
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=password
ORDER_DB_NAME=order_db

# ========================
# Auth Service DB
# ========================
AUTH_DB_USER=dco_user
AUTH_DB_PASSWORD=dco_password
AUTH_DB_NAME=dco_db

# ========================
# Seller Service DB
# ========================
SELLER_DB_USER=dco_user
SELLER_DB_PASSWORD=dco_password
SELLER_DB_NAME=seller_db


PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=password
PAYMENT_DB_NAME=payment_db

# ========================
# Secrets
# ========================
JWT_SECRET=change-me
